# --- Données ---
NEXT_PUBLIC_SUPABASE_URL=https://lwcwucvbxcjmyzrsnszj.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# --- SEO / site ---
# URL de prod, utilisée pour les balises canonical, sitemap, Open Graph.
NEXT_PUBLIC_SITE_URL=https://paris-immobilier.fr

# --- Analytique (Plausible, RGPD-friendly) ---
# Le domaine déclaré côté Plausible (sans https://).
# Laisser vide en dev = aucun tracker chargé.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=paris-immobilier.fr

# --- Google Tag Manager ---
# ID du conteneur GTM (format GTM-XXXXXXX). Trouvable sur tagmanager.google.com
# en haut à droite (à côté de "Prévisualiser"). Laisser vide = pas de GTM chargé.
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# --- Concierge IA (Anthropic) ---
# Crée une clé sur https://console.anthropic.com/
# Modèle utilisé : claude-haiku-4-5 (~€0.001 par requête utilisateur).
ANTHROPIC_API_KEY=sk-ant-xxx

# --- Liens d'affiliation ---
# Une fois inscrit chez chaque partenaire, remplacer par le deeplink avec
# votre identifiant tracker. Tous sont publics et trackables côté analytics.
#
# Pretto (courtier crédit immo) — programme via Awin, ~€80-250/lead
NEXT_PUBLIC_AFFILIATE_PRETTO_URL=https://www.pretto.fr/capacite-emprunt/?clickref=YOUR_AWIN_ID
# Luko (assurance habitation) — programme direct, ~€15-35/souscription
NEXT_PUBLIC_AFFILIATE_LUKO_URL=https://fr.luko.eu/devis/?ref=YOUR_REF
# Liberkeys (agence low-fee) — programme direct, ~€30-80/lead
NEXT_PUBLIC_AFFILIATE_LIBERKEYS_URL=https://www.liberkeys.com/contact?ref=YOUR_REF
# Demeco / Moveasy (déménagement)
NEXT_PUBLIC_AFFILIATE_MOVEASY_URL=https://www.demeco.com/devis?aff=YOUR_REF
